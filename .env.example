# --- Strawberry Notes — example environment file ---
#
# Copy to `.env` and edit. Both docker-compose.yml and `next dev`
# (via @next/env) read this file. Lines are KEY=VALUE; no shell quoting.
#
# Required variables are at the top. Everything below them has a sensible
# default — the app boots fine if you leave the optional sections empty.

# ====================================================================
# Required
# ====================================================================

# 32+ random bytes used by Auth.js to sign session JWT cookies.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Public URL Auth.js uses when issuing callback URLs, AND the override for
# outbound email links (password reset, signup confirmation, notifications).
#
# When unset, email links auto-derive from the request host (so accessing the
# app at http://192.168.1.50:3200 gets you matching links in your inbox).
# Auth.js still needs an explicit value when behind a TLS-terminating proxy
# whose X-Forwarded-* headers you don't fully control — set it to the
# canonical HTTPS URL there (e.g. https://notes.example.com).
# AUTH_URL=http://localhost:3200

# Postgres connection string. The default below matches docker-compose.yml.
# If you bring your own Postgres, point at it here and skip the bundled one.
DATABASE_URL=postgres://strawberry:strawberry@postgres:5432/strawberry

# Postgres password used by the bundled `postgres` service in docker-compose.
# Keep it in sync with the DATABASE_URL above.
POSTGRES_PASSWORD=strawberry

# ====================================================================
# Public-launch hardening (recommended)
# ====================================================================

# Whether the public /signup page and POST /api/auth/signup are enabled.
# Default: false. When false, sign-ups can only be created by an operator
# running `npm run user:create -- <email>` (see docs/technical/auth.md).
# Set to `true` only on instances where you intend strangers to register.
ALLOW_PUBLIC_SIGNUP=false

# ====================================================================
# Uploads
# ====================================================================

# Where image attachments live on disk. Inside the container this maps to
# the `uploads` named volume; on the host it defaults to ./data/uploads.
UPLOAD_DIR=/data/uploads

# Per-file upload cap (megabytes). Anything over this is rejected at the API.
MAX_UPLOAD_MB=10

# ====================================================================
# Semantic search (optional)
# ====================================================================
#
# Leave EMBEDDING_ENDPOINT empty to disable semantic search entirely. The
# app will start fine; the /api/notes/search/semantic endpoint will return
# a clear "not configured" error and the in-process worker will idle.
#
# Any provider that speaks OpenAI's POST /v1/embeddings shape works:
# OpenAI, Ollama, llama.cpp, vLLM, LM Studio, and similar.

# Base URL of the embeddings provider, ending in /v1.
#   OpenAI:     https://api.openai.com/v1
#   Ollama:     http://host.docker.internal:11434/v1
#   llama.cpp:  http://host.docker.internal:8080/v1
EMBEDDING_ENDPOINT=

# Model id to send. Must match one of the models the endpoint serves.
#   OpenAI: text-embedding-3-small (1536 dims) or text-embedding-3-large (3072 dims)
#   Ollama: nomic-embed-text (768) or mxbai-embed-large (1024)
EMBEDDING_MODEL=

# Bearer credential for the endpoint. Optional for most local providers.
EMBEDDING_API_KEY=

# Vector column dimensionality. MUST match the provider's output dimension.
# Changing this is a destructive migration — see docs/technical/database.md.
EMBEDDING_DIMS=1024

# ====================================================================
# SMTP / email (optional but recommended)
# ====================================================================
#
# Leave SMTP_HOST empty to disable email entirely. The app still boots,
# the /forgot-password page surfaces a "operator must reset" message,
# and `npm run user:reset` remains the recovery path.
#
# When SMTP_HOST is set, self-service password reset is enabled:
# /forgot-password emails a one-hour, single-use reset link.
#
# Any SMTP relay works — Postmark, Resend, SendGrid, SES, Mailgun, or
# your own postfix. They all expose SMTP; there is no per-provider
# adapter.

# SMTP server hostname.
SMTP_HOST=

# SMTP port. 587 (STARTTLS) is the most common; 465 with SMTP_SECURE=true
# for implicit TLS; 25 for unencrypted (don't use over the internet).
SMTP_PORT=587

# Authentication (optional — some local relays don't require it).
SMTP_USER=
SMTP_PASS=

# Force implicit TLS on connect. Default false; STARTTLS is negotiated
# as needed by nodemailer when this is unset/false.
SMTP_SECURE=false

# Address messages are From: — must be a deliverable mailbox at the
# domain your SMTP relay is allowed to send for. Required when SMTP_HOST
# is set. Format: `Strawberry Notes <noreply@example.com>` or
# `noreply@example.com`.
SMTP_FROM=

# When `true`, public signup creates accounts with the email unconfirmed
# and emails a confirmation link. The credentials provider rejects
# sign-in until the link is clicked. Operator-created accounts via
# `npm run user:create` are always pre-confirmed. Implies SMTP must be
# configured above. Default: false.
REQUIRE_EMAIL_CONFIRMATION=false

# ====================================================================
# Private Notes (v1.5 — opt-in client-side encryption)
# ====================================================================

# When `true`, expose the Private Notes UI surface: Settings → Private
# Notes panel, the editor's lock toggle, and the locked-overlay on
# encrypted notes. Server-side schema, REST routes, and crypto land
# regardless — only the user-facing affordances are gated.
#
# Default: false. Flip to `true` once MCP/clipper invisibility gating
# (PR 3) lands; on a fresh install you can enable it from day one.
NEXT_PUBLIC_PRIVATE_NOTES=false

# ====================================================================
# Misc
# ====================================================================

# Override the host port docker-compose publishes the app on.
# (Inside the container the app always listens on 3000.)
APP_PORT=3200
