{
  "manifest_version": 3,
  "name": "Strawberry Notes Web Clipper",
  "short_name": "Strawberry Clipper",
  "version": "0.1.0",
  "description": "Clip the current page or selection to your Strawberry Notes server as Markdown.",
  "action": {
    "default_title": "Clip to Strawberry Notes",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "strawberry-notes-clipper@strawberry.local",
      "strict_min_version": "121.0"
    }
  }
}
