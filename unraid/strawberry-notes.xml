<?xml version="1.0"?>
<Container version="2">
  <Name>strawberry-notes</Name>
  <Repository>ghcr.io/straplocked/strawberry-notes:latest</Repository>
  <Registry>https://ghcr.io/straplocked/strawberry-notes</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/straplocked/strawberry-notes/issues</Support>
  <Project>https://github.com/straplocked/strawberry-notes</Project>
  <Overview>
Self-hosted, MIT-licensed, multi-user, AI-native rich-text notes app.
TipTap editor, [[wiki-link]] backlinks, semantic search over any
OpenAI-compatible embeddings endpoint, full-workspace ZIP export, a
Chrome/Firefox web clipper, and a first-class MCP endpoint.

Requires a Postgres 16+ database with the `pgvector` extension.
Use the pgvector/pgvector:pg16 image (drop-in for postgres:16) if
your existing Postgres doesn't have pgvector installed.

First-time setup:
  1. Create a database and user for Strawberry on your Postgres.
  2. Fill in DATABASE_URL and AUTH_SECRET below.
  3. Set ALLOW_PUBLIC_SIGNUP to `true` for the initial install,
     visit /signup, create your admin account, then set it back to
     `false` and redeploy.

Docs: https://github.com/straplocked/strawberry-notes/tree/main/docs
  </Overview>
  <Category>Productivity: Tools: Cloud:</Category>
  <WebUI>http://[IP]:[PORT:3000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/straplocked/strawberry-notes/main/unraid/strawberry-notes.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/straplocked/strawberry-notes/main/public/icons/icon-512.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires>
A Postgres 16+ database with pgvector. The DATABASE_URL field accepts
the standard `postgres://user:pass@host:5432/db` shape.
  </Requires>
  <Config Name="WebUI" Target="3000" Default="3200" Mode="tcp" Description="Host port the WebUI is published on. Default: 3200." Type="Port" Display="always" Required="true" Mask="false">3200</Config>
  <Config Name="DATABASE_URL" Target="DATABASE_URL" Default="postgres://strawberry:CHANGE_ME@192.168.1.10:5432/strawberry" Mode="" Description="Full Postgres connection string. The user must own the target database; Strawberry will run migrations on first boot. Requires the pgvector extension." Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="AUTH_SECRET" Target="AUTH_SECRET" Default="" Mode="" Description="32+ bytes of base64 entropy used to sign session cookies. Generate one on Unraid's terminal: `openssl rand -base64 32`. Keep this stable across restarts — rotating it logs everyone out." Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="AUTH_URL" Target="AUTH_URL" Default="" Mode="" Description="Public URL where Strawberry is reachable, e.g. https://notes.example.com. Leave blank for LAN access; set explicitly when behind a TLS-terminating proxy that strips X-Forwarded-* headers." Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="ALLOW_PUBLIC_SIGNUP" Target="ALLOW_PUBLIC_SIGNUP" Default="false" Mode="" Description="Set to `true` for the initial install so you can create your admin account at /signup, then flip back to `false` and redeploy. Leave `false` afterwards unless you want strangers to register." Type="Variable" Display="always" Required="true" Mask="false">false</Config>
  <Config Name="Uploads" Target="/data" Default="/mnt/user/appdata/strawberry-notes/data" Mode="rw" Description="Where uploaded images live on disk. Survives container recreates." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/strawberry-notes/data</Config>

  <Config Name="MAX_UPLOAD_MB" Target="MAX_UPLOAD_MB" Default="10" Mode="" Description="Per-file upload size cap in megabytes." Type="Variable" Display="advanced" Required="false" Mask="false">10</Config>

  <Config Name="REQUIRE_EMAIL_CONFIRMATION" Target="REQUIRE_EMAIL_CONFIRMATION" Default="false" Mode="" Description="When true, signup creates accounts unconfirmed and emails a confirmation link. Implies SMTP must be configured below." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>

  <Config Name="SMTP_HOST" Target="SMTP_HOST" Default="" Mode="" Description="SMTP relay hostname for password-reset and notification emails. Leave blank to disable email entirely." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="SMTP_PORT" Target="SMTP_PORT" Default="587" Mode="" Description="SMTP port. 587 (STARTTLS) is most common; 465 with SMTP_SECURE=true for implicit TLS." Type="Variable" Display="advanced" Required="false" Mask="false">587</Config>
  <Config Name="SMTP_USER" Target="SMTP_USER" Default="" Mode="" Description="Optional SMTP auth username." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="SMTP_PASS" Target="SMTP_PASS" Default="" Mode="" Description="Optional SMTP auth password." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="SMTP_FROM" Target="SMTP_FROM" Default="" Mode="" Description="From: address on outbound mail. Required when SMTP_HOST is set." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="SMTP_SECURE" Target="SMTP_SECURE" Default="false" Mode="" Description="`true` forces implicit TLS at connect time (port 465 deployments)." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>

  <Config Name="EMBEDDING_ENDPOINT" Target="EMBEDDING_ENDPOINT" Default="" Mode="" Description="OpenAI-compatible embeddings endpoint (`/v1`). Leave blank to disable semantic search; everything else still works." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="EMBEDDING_MODEL" Target="EMBEDDING_MODEL" Default="" Mode="" Description="Model id, e.g. text-embedding-3-small (OpenAI) or nomic-embed-text (Ollama)." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="EMBEDDING_API_KEY" Target="EMBEDDING_API_KEY" Default="" Mode="" Description="Bearer token for the embeddings provider. Optional for local providers like Ollama." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="EMBEDDING_DIMS" Target="EMBEDDING_DIMS" Default="1024" Mode="" Description="Vector dimension. MUST match the provider's output dim. Default 1024 matches mxbai-embed-large and similar." Type="Variable" Display="advanced" Required="false" Mask="false">1024</Config>

  <Config Name="PASSWORD_AUTH" Target="PASSWORD_AUTH" Default="true" Mode="" Description="Email/password sign-in. Set to `false` for OIDC-only or proxy-only deployments." Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>
  <Config Name="TOTP_ENABLED" Target="TOTP_ENABLED" Default="false" Mode="" Description="Enable per-user TOTP/2FA enrollment from Settings → Security." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="OIDC_ENABLED" Target="OIDC_ENABLED" Default="false" Mode="" Description="Enable OIDC SSO. Requires the four OIDC_* fields below." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="OIDC_ISSUER" Target="OIDC_ISSUER" Default="" Mode="" Description="OIDC issuer URL, e.g. https://auth.example.com/application/o/strawberry/" Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="OIDC_CLIENT_ID" Target="OIDC_CLIENT_ID" Default="" Mode="" Description="OIDC client id." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
  <Config Name="OIDC_CLIENT_SECRET" Target="OIDC_CLIENT_SECRET" Default="" Mode="" Description="OIDC client secret." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="OIDC_NAME" Target="OIDC_NAME" Default="SSO" Mode="" Description="Label for the SSO sign-in button on /login." Type="Variable" Display="advanced" Required="false" Mask="false">SSO</Config>
  <Config Name="OIDC_AUTO_PROVISION" Target="OIDC_AUTO_PROVISION" Default="false" Mode="" Description="JIT-create local users on first OIDC sign-in (requires the IdP to set email_verified=true)." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="OIDC_TRUST_EMAIL_FOR_LINKING" Target="OIDC_TRUST_EMAIL_FOR_LINKING" Default="false" Mode="" Description="DANGER: auto-link OIDC sign-ins to existing email-matching local users. Account-takeover risk if your IdP allows arbitrary email assignment. Off by default." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>

  <Config Name="PROXY_AUTH" Target="PROXY_AUTH" Default="false" Mode="" Description="Bypass first-party login and trust a forward-auth header (Authentik forward-auth, Authelia, oauth2-proxy). Hides /login. Requires PROXY_AUTH_SHARED_SECRET." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="PROXY_AUTH_USER_HEADER" Target="PROXY_AUTH_USER_HEADER" Default="x-authentik-username" Mode="" Description="Header carrying the trusted username." Type="Variable" Display="advanced" Required="false" Mask="false">x-authentik-username</Config>
  <Config Name="PROXY_AUTH_EMAIL_HEADER" Target="PROXY_AUTH_EMAIL_HEADER" Default="x-authentik-email" Mode="" Description="Optional companion email header." Type="Variable" Display="advanced" Required="false" Mask="false">x-authentik-email</Config>
  <Config Name="PROXY_AUTH_SHARED_SECRET" Target="PROXY_AUTH_SHARED_SECRET" Default="" Mode="" Description="REQUIRED when PROXY_AUTH=true. The proxy must forward `X-Forward-Auth-Secret: <this>` on every request; mismatch → 401. Distinguishes proxy traffic from clients spoofing the username header." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="PROXY_AUTH_LOGOUT_URL" Target="PROXY_AUTH_LOGOUT_URL" Default="" Mode="" Description="Where the sign-out button points in proxy mode (e.g. /outpost.goauthentik.io/sign_out for Authentik forward-auth). Unset → button hidden." Type="Variable" Display="advanced" Required="false" Mask="false"></Config>
</Container>
